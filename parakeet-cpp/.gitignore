# ggml is cloned via scripts/setup-ggml.sh at a pinned commit; don't track it.
ggml/

# Python virtualenv for the converter + reference-dump scripts.
venv/
.venv/
.venv-*/
.pip-cache/
__pycache__/
*.pyc

# CMake build trees.
build/
build-*/

# Downloaded NeMo checkpoint + converted GGUF (large, not tracked).
models/
*.nemo
*.gguf

# Reference .npy dumps for per-stage validation (not tracked).
artifacts/*
*.npy

# ...but we do want the benchmark JSON snapshots checked in so PROGRESS.md
# can cite them for before/after optimization comparisons.
!artifacts/bench/
!artifacts/bench/**

# IDE / editor / OS cruft.
.DS_Store
.vscode/
.idea/
*.swp
